{
  "rules": {
    "preset-ja-spacing": {
      "ja-space-between-half-and-full-width": {
        "space": "always"
      },
      "ja-space-around-code": false,
      "ja-space-around-link": false,
      "ja-no-space-around-slash": false,
      "ja-space-around-strong": false
    }
  },
  "filters": {
    "comments": true
  }
}
