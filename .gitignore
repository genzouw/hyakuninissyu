### https://raw.github.com/github/gitignore/5c5a1b536b6f9bf11515518f03d58addaf29f681/Node.gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript v1 declaration files
typings/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache

# next.js build output
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/


dist/

# AI agents
.claude/
!.cursor/rules/
.cursor/*
.aider*
!.aider.conf.yml
!.aider.instruction.md
.continue/
.windsurf/
.cline/
*-report.md

# Secrets
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
id_rsa*
id_ed25519*
*credentials*.json
*service-account*.json

# Environment variables
.env.*
!.env.example

# Package manager configs
.npmrc
.yarnrc
.bunfig.toml
bunfig.toml

# Database dumps / Backups
*.db
*.sqlite
*.sqlite3
*.dump
*.bak

# Infrastructure state
*.tfstate
*.tfstate.*
repomix-output.*

# Cloud config directories and IaC variables (Security/Leak Prevention)
.aws/
.kube/
.gcp/
.azure/
*.tfvars
*.auto.tfvars

# Additional AI agent traces
.roo/
