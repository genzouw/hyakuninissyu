{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": false,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "instructionFilePath": "CLAUDE.md"
  },
  "include": [
    "src/**/*",
    "package.json",
    "README.md",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "cody.json",
    ".cursorrules",
    ".cursor/rules/**",
    ".clinerules",
    ".windsurfrules",
    ".github/copilot-instructions.md",
    ".github/actions/**",
    ".github/workflows/**",
    ".coderabbit.yaml",
    "sweep.yaml",
    ".pr_agent.toml",
    ".aider.conf.yml",
    ".aider.instruction.md",
    ".bloopignore",
    "static/llms.txt",
    "eslint.config.js",
    ".pre-commit-config.yaml",
    "repomix.config.json",
    "commitlint.config.js",
    "test/unit/jest.conf.js",
    "docs/**/*"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "dist/",
      "build/",
      "coverage/",
      "**/*.png",
      "**/*.ico",
      "**/*.lock",
      "bun.lockb",
      "**/*.sarif",
      ".secrets.baseline"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
