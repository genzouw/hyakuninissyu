npx lint-staged

# pre-commitフレームワークがインストールされている場合は、包括的なシークレットスキャンを実行します
if command -v pre-commit &> /dev/null; then
  echo "🔒 pre-commitフック（gitleaksやdetect-secretsを含む）を実行中..."
  pre-commit run --hook-stage commit
else
  echo "⚠️ pre-commitがローカルにインストールされていません。包括的なシークレットスキャンをスキップします。"
  echo "   包括的なセキュリティチェックを有効にするには、'pip install pre-commit detect-secrets==1.5.0' を実行してください。"

  # pre-commitがない場合でも、gitleaksが利用可能であれば直接実行するフォールバック
  if command -v gitleaks &> /dev/null; then
    echo "🔒 フォールバックのローカルgitleaksチェックを実行中..."
    gitleaks protect --staged --verbose
  fi
fi

# src/ 以下の変更ファイルに対する lint とテストの実行
changed_files=$(git diff --cached --name-only -- 'src/')

if [ -n "$changed_files" ]; then
  echo "🔍 Running lint..."
  bun run lint
  echo "🧪 Running tests..."
  bun run unit
fi
